{
  "name": "gamebasebox",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint",
    "test:frontend": "vitest run",
    "test:backend": "cargo test --manifest-path src-tauri/Cargo.toml -- --test-threads=1",
    "test:e2e": "playwright test",
    "coverage:frontend": "vitest run --coverage",
    "coverage:backend": "cargo llvm-cov --manifest-path src-tauri/Cargo.toml --ignore-filename-regex \"(lib\\\\.rs|main\\\\.rs|commands[/\\\\\\\\]system\\\\.rs)\" --fail-under-lines 80 -- --test-threads=1",
    "db:convert": "node scripts/convert_csv_to_sqlite.js",
    "db:audit": "node scripts/check_sqlite_support.js",
    "db:import": "node scripts/db_pipeline.js",
    "sounds:convert": "node scripts/convert_ui_sounds_to_mp3.js",
    "tauri": "tauri",
    "tauri:dev": "tauri-dev.bat",
    "tauri:build": "tauri-build.bat",
    "test": "npm run test:frontend",
    "setup:emu": "node scripts/setup_emulator.js",
    "postinstall": "npm run setup:emu"
  },
  "dependencies": {
    "@emulatorjs/core-vice_x64": "^4.2.3",
    "@emulatorjs/core-vice_x64sc": "^4.2.3",
    "@emulatorjs/emulatorjs": "^4.2.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^12.9.0",
    "csv-parse": "^6.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
